rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny rule for safe-netting
    match /{document=**} {
      allow read, write: if false;
    }

    // Explicit users rules
    match /users/{userId} {
      allow read, write: if true;

      match /calls/{callId} {
        allow read, write: if true;
      }
    }
  }
}
